{
  "name": "@profullstack/sh1pt-openapi",
  "version": "0.1.15",
  "description": "OpenAPI loader/IR + generators for SDKs, MCP servers, and docs sites.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/profullstack/sh1pt.git",
    "directory": "packages/openapi"
  },
  "homepage": "https://sh1pt.com",
  "bugs": "https://github.com/profullstack/sh1pt/issues",
  "keywords": ["sh1pt", "openapi", "sdk", "mcp", "docs", "generator"],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./core": "./src/core/index.ts",
    "./gen-sdk-ts": "./src/gen-sdk-ts/index.ts",
    "./gen-mcp": "./src/gen-mcp/index.ts",
    "./gen-docs": "./src/gen-docs/index.ts"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./core": { "types": "./dist/core/index.d.ts", "import": "./dist/core/index.js" },
      "./gen-sdk-ts": { "types": "./dist/gen-sdk-ts/index.d.ts", "import": "./dist/gen-sdk-ts/index.js" },
      "./gen-mcp": { "types": "./dist/gen-mcp/index.d.ts", "import": "./dist/gen-mcp/index.js" },
      "./gen-docs": { "types": "./dist/gen-docs/index.d.ts", "import": "./dist/gen-docs/index.js" }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "yaml": "^2.6.0"
  }
}
