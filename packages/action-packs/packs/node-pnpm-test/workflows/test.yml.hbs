name: test

on:
  pull_request:
  push:
    branches: [{{pushBranch}}]

permissions:
  contents: read

jobs:
  test:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v4

      - uses: pnpm/action-setup@v4
        with:
          version: {{pnpmVersion}}

      - uses: actions/setup-node@v4
        with:
          node-version: {{nodeVersion}}
          cache: pnpm

      - run: {{installCommand}}

      - run: {{testCommand}}
        env:
          CI: true
